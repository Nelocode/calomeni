---
import Layout from '../../layouts/Layout.astro';
import { db, postsPages } from '../../db/client';
import { eq, and, desc } from 'drizzle-orm';

export const prerender = false;

// Obtener todas las entradas de blog publicadas
const posts = await db
  .select()
  .from(postsPages)
  .where(
    and(
      eq(postsPages.type, 'post'),
      eq(postsPages.published, 1)
    )
  )
  .orderBy(desc(postsPages.createdAt));
---

<Layout title="Blog | CMS Base">
  <div class="blog-container">
    <header class="blog-header">
      <h1>Artículos del Blog</h1>
      <p class="subtitle">Explora noticias, tutoriales y artículos creados directamente en nuestro CMS.</p>
      <div class="header-divider"></div>
    </header>

    {posts.length === 0 ? (
      <div class="empty-blog glass-panel">
        <span class="empty-icon">✍️</span>
        <h3>No hay publicaciones aún</h3>
        <p>Inicia sesión en el administrador para redactar tu primer post de blog.</p>
        <a href="/admin/login" class="btn btn-primary">Ir al Administrador</a>
      </div>
    ) : (
      <div class="blog-grid">
        {posts.map((post) => (
          <article class="post-card glass-panel">
            <div class="post-card-content">
              <span class="post-category">Blog</span>
              <h2>{post.title}</h2>
              <p class="post-date">
                {new Date(post.createdAt).toLocaleDateString('es-CO', { dateStyle: 'medium' })}
              </p>
              {post.metaDescription && <p class="post-excerpt">{post.metaDescription}</p>}
              <a href={`/blog/${post.slug}`} class="btn btn-secondary card-btn">Leer Más ➔</a>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>

<style>
  .blog-container {
    max-width: 1000px;
    margin: 40px auto;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .blog-header h1 {
    font-size: 3rem;
    font-weight: 800;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 12px;
  }

  .blog-header .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 24px auto;
  }

  .header-divider {
    width: 80px;
    height: 4px;
    background: var(--gradient-primary);
    margin: 0 auto;
    border-radius: var(--radius-full);
  }

  /* Estado vacío */
  .empty-blog {
    text-align: center;
    padding: 60px 40px;
    max-width: 500px;
    margin: 0 auto;
  }

  .empty-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 20px;
  }

  .empty-blog h3 {
    font-size: 1.3rem;
    margin-bottom: 8px;
  }

  .empty-blog p {
    font-size: 0.95rem;
    margin-bottom: 24px;
  }

  /* Grid de publicaciones */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .post-card-content {
    padding: 30px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-category {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-primary-light);
    letter-spacing: 0.05em;
    margin-bottom: 12px;
    display: inline-block;
  }

  .post-card h2 {
    font-size: 1.4rem;
    margin-bottom: 8px;
    line-height: 1.25;
    color: var(--text-main);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-muted-dark);
    margin-bottom: 16px;
  }

  .post-excerpt {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text-muted);
    margin-bottom: 24px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-btn {
    align-self: flex-start;
    padding: 8px 18px;
    font-size: 0.85rem;
    border-radius: var(--radius-sm);
  }
</style>

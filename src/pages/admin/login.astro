---
import '../../styles/global.css';
import '../../styles/admin.css';
import { db, users } from '../../db/client';
import { hashPassword, verifyPassword, createSession } from '../../lib/auth';

export const prerender = false;

// Si ya hay una sesión activa, redirigir al panel
const sessionId = Astro.cookies.get('session_id')?.value;
const auth = sessionId ? await validateSession(sessionId) : null;
if (auth) {
  return Astro.redirect('/admin');
}

// Comprobar si ya existe algún administrador registrado
const existingUsers = await db.select().from(users).limit(1);
const isFirstRun = existingUsers.length === 0;

let errorMsg = '';
let successMsg = '';

// Procesar el envío del formulario
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const username = formData.get('username')?.toString().trim();
    const password = formData.get('password')?.toString();

    if (!username || !password) {
      errorMsg = 'Por favor, rellena todos los campos.';
    } else if (password.length < 6) {
      errorMsg = 'La contraseña debe tener al menos 6 caracteres.';
    } else {
      if (isFirstRun) {
        // --- Registro del Administrador Inicial ---
        const userId = crypto.randomUUID();
        const hashedPassword = await hashPassword(password);
        
        await db.insert(users).values({
          id: userId,
          username,
          hashedPassword,
        });
        
        // Iniciar sesión inmediatamente
        const sessionId = await createSession(userId);
        
        Astro.cookies.set('session_id', sessionId, {
          path: '/',
          httpOnly: true,
          secure: import.meta.env.PROD,
          sameSite: 'lax',
          maxAge: 60 * 60 * 24 * 30, // 30 días
        });
        
        return Astro.redirect('/admin');
      } else {
        // --- Inicio de Sesión Normal ---
        const userResult = await db
          .select()
          .from(users)
          .where(eq(users.username, username))
          .limit(1);
          
        const user = userResult[0];
        
        if (user && await verifyPassword(password, user.hashedPassword)) {
          const sessionId = await createSession(user.id);
          
          Astro.cookies.set('session_id', sessionId, {
            path: '/',
            httpOnly: true,
            secure: import.meta.env.PROD,
            sameSite: 'lax',
            maxAge: 60 * 60 * 24 * 30, // 30 días
          });
          
          return Astro.redirect('/admin');
        } else {
          errorMsg = 'Nombre de usuario o contraseña incorrectos.';
        }
      }
    }
  } catch (err) {
    errorMsg = 'Ocurrió un error inesperado al procesar la solicitud.';
    console.error(err);
  }
}

// Necesitamos importar el comparador eq de Drizzle
import { eq } from 'drizzle-orm';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{isFirstRun ? 'Configurar Administrador' : 'Iniciar Sesión'} | CMS Base</title>
  </head>
  <body class="login-body admin-body">
    <div class="login-wrapper">
      <div class="login-card glass-panel animate-fade-in">
        <div class="login-header">
          <div class="brand">
            <span>CMS</span>Base
          </div>
          <h1>{isFirstRun ? 'Crear Administrador Inicial' : 'Acceso Administrativo'}</h1>
          <p class="subtitle">
            {isFirstRun 
              ? 'Configura tu cuenta de administrador para empezar a usar el CMS.' 
              : 'Introduce tus credenciales para acceder al panel de control.'}
          </p>
        </div>

        {errorMsg && (
          <div class="alert alert-error">
            <span class="alert-icon">⚠️</span>
            <p>{errorMsg}</p>
          </div>
        )}

        <form method="POST" class="login-form">
          <div class="form-group">
            <label for="username" class="form-label">Nombre de Usuario</label>
            <input 
              type="text" 
              id="username" 
              name="username" 
              class="form-input" 
              placeholder="ej. admin" 
              required 
              autocomplete="username"
            />
          </div>

          <div class="form-group">
            <label for="password" class="form-label">Contraseña</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              class="form-input" 
              placeholder="••••••••" 
              required 
              autocomplete="current-password"
            />
          </div>

          <button type="submit" class="btn btn-primary login-btn">
            {isFirstRun ? 'Inicializar y Entrar 🚀' : 'Iniciar Sesión 🚪'}
          </button>
        </form>
      </div>
    </div>
  </body>
</html>

<style>
  .login-body {
    background-color: hsl(222, 25%, 3%);
    background-image: 
      radial-gradient(at 10% 20%, hsla(263, 90%, 63%, 0.1) 0px, transparent 50%),
      radial-gradient(at 90% 80%, hsla(190, 95%, 45%, 0.08) 0px, transparent 50%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .login-wrapper {
    width: 100%;
    max-width: 440px;
  }

  .login-card {
    padding: 40px;
    border-radius: var(--radius-lg);
    background: hsla(222, 25%, 7%, 0.85);
  }

  .login-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .brand {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 16px;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .brand span {
    color: var(--text-main);
    -webkit-text-fill-color: initial;
    margin-right: 2px;
  }

  .login-header h1 {
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .login-form {
    display: flex;
    flex-direction: column;
  }

  .login-btn {
    width: 100%;
    margin-top: 10px;
    padding: 12px;
    font-size: 1rem;
  }

  /* Alertas */
  .alert {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    margin-bottom: 24px;
    font-size: 0.9rem;
    animation: fadeIn 0.3s ease;
  }

  .alert-error {
    background-color: hsla(350, 89%, 60%, 0.15);
    border: 1px solid hsla(350, 89%, 60%, 0.3);
    color: hsl(350, 100%, 75%);
  }

  .alert-icon {
    font-size: 1.1rem;
  }
</style>

---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, postsPages } from '../../../db/client';
import { desc, eq } from 'drizzle-orm';

export const prerender = false;

let successMsg = '';
let errorMsg = '';

// Procesar acciones de eliminación u otras
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action')?.toString();
    const id = formData.get('id')?.toString();

    if (action === 'delete' && id) {
      await db.delete(postsPages).where(eq(postsPages.id, id));
      successMsg = 'Página eliminada con éxito.';
    }
  } catch (err) {
    errorMsg = 'No se pudo eliminar el elemento.';
    console.error(err);
  }
}

// Consultar todas las páginas y entradas de blog
const items = await db
  .select()
  .from(postsPages)
  .orderBy(desc(postsPages.updatedAt));
---

<AdminLayout title="Páginas y Blog">
  {successMsg && (
    <div class="alert alert-success">
      <span>✅</span>
      <p>{successMsg}</p>
    </div>
  )}

  {errorMsg && (
    <div class="alert alert-error">
      <span>⚠️</span>
      <p>{errorMsg}</p>
    </div>
  )}

  <div class="page-actions-header">
    <div class="search-filter">
      <p class="count-label">Total: <strong>{items.length}</strong> elementos</p>
    </div>
    <a href="/admin/paginas/crear" class="btn btn-primary">
      <span>➕</span> Crear Página o Post
    </a>
  </div>

  <div class="dashboard-card glass-panel">
    {items.length === 0 ? (
      <div class="empty-state">
        <span class="empty-icon">📂</span>
        <p>No hay contenido creado aún.</p>
        <p class="empty-sub">Crea tu primera página estática o entrada de blog para verla aquí.</p>
      </div>
    ) : (
      <div class="table-responsive">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Título</th>
              <th>Ruta / Slug</th>
              <th>Tipo</th>
              <th>Estado</th>
              <th>Última Modificación</th>
              <th class="actions-th">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {items.map((item) => (
              <tr>
                <td>
                  <span class="item-title">{item.title}</span>
                </td>
                <td>
                  <code class="slug-code">
                    {item.type === 'post' ? `/blog/${item.slug}` : `/${item.slug}`}
                  </code>
                </td>
                <td>
                  <span class={`type-badge type-${item.type}`}>
                    {item.type === 'post' ? 'Blog Post' : 'Página Estática'}
                  </span>
                </td>
                <td>
                  <span class={`status-dot-badge ${item.published === 1 ? 'pub' : 'draft'}`}>
                    <span class="dot"></span>
                    {item.published === 1 ? 'Publicado' : 'Borrador'}
                  </span>
                </td>
                <td>{new Date(item.updatedAt).toLocaleString('es-CO', { dateStyle: 'short', timeStyle: 'short' })}</td>
                <td>
                  <div class="table-actions">
                    <a href={item.type === 'post' ? `/blog/${item.slug}` : `/${item.slug}`} target="_blank" class="action-btn btn-view" title="Previsualizar">
                      👁️
                    </a>
                    <a href={`/admin/paginas/editar/${item.id}`} class="action-btn btn-edit" title="Editar">
                      ✏️
                    </a>
                    <form method="POST" class="delete-form" onsubmit="return confirm('¿Estás seguro de que deseas eliminar esta página?')">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id" value={item.id} />
                      <button type="submit" class="action-btn btn-delete" title="Eliminar">
                        🗑️
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AdminLayout>

<style>
  .page-actions-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .count-label {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .slug-code {
    background: hsla(222, 25%, 5%, 0.5);
    border: 1px solid var(--border-light);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    color: var(--color-secondary-light);
  }

  /* Badges */
  .type-badge {
    display: inline-block;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .type-page { background: hsla(220, 90%, 55%, 0.15); color: hsl(200, 100%, 70%); }
  .type-post { background: hsla(280, 90%, 65%, 0.15); color: hsl(280, 100%, 75%); }

  .status-dot-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .status-dot-badge .dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
  }

  .status-dot-badge.pub { color: var(--text-main); }
  .status-dot-badge.pub .dot { background-color: var(--color-success); box-shadow: 0 0 6px var(--color-success); }
  .status-dot-badge.draft { color: var(--text-muted); }
  .status-dot-badge.draft .dot { background-color: var(--text-muted-dark); }

  .item-title {
    font-weight: 600;
    color: var(--text-main);
  }

  /* Tabla y Acciones */
  .actions-th {
    text-align: right;
  }

  .table-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
  }

  .action-btn {
    background: hsla(222, 25%, 15%, 0.5);
    border: 1px solid var(--border-light);
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 0.9rem;
    transition: var(--transition-fast);
  }

  .action-btn:hover {
    transform: translateY(-2px);
    background: var(--bg-surface-hover);
  }

  .btn-view:hover { border-color: var(--color-secondary); }
  .btn-edit:hover { border-color: var(--color-primary); }
  .btn-delete:hover { border-color: var(--color-danger); background-color: hsla(350, 89%, 60%, 0.1); }

  .delete-form {
    margin: 0;
    display: inline;
  }

  .delete-form button {
    display: inline-flex;
    padding: 0;
  }

  /* Alertas */
  .alert {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    margin-bottom: 24px;
    font-size: 0.9rem;
  }

  .alert-success {
    background-color: hsla(142, 70%, 45%, 0.15);
    border: 1px solid hsla(142, 70%, 45%, 0.3);
    color: hsl(142, 100%, 75%);
  }

  .alert-error {
    background-color: hsla(350, 89%, 60%, 0.15);
    border: 1px solid hsla(350, 89%, 60%, 0.3);
    color: hsl(350, 100%, 75%);
  }
</style>

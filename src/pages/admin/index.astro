---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db, postsPages, products, orders } from '../../db/client';
import { count, desc } from 'drizzle-orm';
import { getSetting } from '../../lib/settings';

export const prerender = false;

// Consultar configuración de tienda
const isStoreEnabled = (await getSetting('enable_store', 'true')) === 'true';

// Consultas a base de datos para estadísticas reales
const pagesCountResult = await db.select({ value: count() }).from(postsPages);
const totalPages = pagesCountResult[0].value;

const recentContent = await db
  .select()
  .from(postsPages)
  .orderBy(desc(postsPages.updatedAt))
  .limit(5);

let totalProducts = 0;
let totalOrders = 0;
let totalEarnings = 0;
let recentOrders: any[] = [];

if (isStoreEnabled) {
  const productsCountResult = await db.select({ value: count() }).from(products);
  totalProducts = productsCountResult[0].value;

  recentOrders = await db
    .select()
    .from(orders)
    .orderBy(desc(orders.createdAt))
    .limit(5);

  totalOrders = (await db.select({ value: count() }).from(orders))[0].value;

  // Sumar total de ventas reales
  const allOrders = await db.select({ total: orders.total }).from(orders);
  totalEarnings = allOrders.reduce((sum, o) => sum + o.total, 0);
}

// Formateador de moneda
const formatCurrency = (value: number) => {
  return new Intl.NumberFormat('es-CO', {
    style: 'currency',
    currency: 'COP',
    minimumFractionDigits: 0,
  }).format(value);
};
---

<AdminLayout title="Escritorio / Telemetría">
  <!-- Grid de Estadísticas (Condicional según la tienda) -->
  <div class="stats-grid" style={!isStoreEnabled ? "grid-template-columns: 1fr;" : ""}>
    <div class="stat-card hud-panel animate-pulse-slow">
      <div class="stat-icon icon-blue">📄</div>
      <div class="stat-info">
        <h3>Páginas y Entradas</h3>
        <p class="stat-number">{totalPages}</p>
        <span class="stat-label">Registros en el sistema</span>
      </div>
    </div>

    {isStoreEnabled && (
      <>
        <div class="stat-card hud-panel">
          <div class="stat-icon icon-purple">🛍️</div>
          <div class="stat-info">
            <h3>Productos</h3>
            <p class="stat-number">{totalProducts}</p>
            <span class="stat-label">En catálogo activo</span>
          </div>
        </div>

        <div class="stat-card hud-panel">
          <div class="stat-icon icon-cyan">💳</div>
          <div class="stat-info">
            <h3>Pedidos</h3>
            <p class="stat-number">{totalOrders}</p>
            <span class="stat-label">Transacciones procesadas</span>
          </div>
        </div>

        <div class="stat-card hud-panel">
          <div class="stat-icon icon-green">💵</div>
          <div class="stat-info">
            <h3>Ganancias</h3>
            <p class="stat-number">{formatCurrency(totalEarnings)}</p>
            <span class="stat-label">Ingresos del sistema</span>
          </div>
        </div>
      </>
    )}
  </div>

  <!-- Contenedor de dos columnas -->
  <div class="dashboard-grid">
    <!-- Columna Izquierda: Dinámica según la tienda -->
    {isStoreEnabled ? (
      <div class="dashboard-card hud-panel">
        <div class="card-header">
          <h2>Pedidos Recientes</h2>
          <a href="/admin/ordenes" class="btn btn-secondary btn-sm">Ver Historial</a>
        </div>
        <div class="card-body">
          {recentOrders.length === 0 ? (
            <div class="empty-state">
              <span class="empty-icon">🫙</span>
              <p>No se registran transacciones.</p>
              <p class="empty-sub">Las compras de tus clientes se reflejarán aquí.</p>
            </div>
          ) : (
            <div class="table-responsive">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Comprador</th>
                    <th>Fecha</th>
                    <th>Total</th>
                    <th>Estado</th>
                  </tr>
                </thead>
                <tbody>
                  {recentOrders.map((order) => (
                    <tr>
                      <td>
                        <div class="customer-info">
                          <span class="customer-name">{order.customerName}</span>
                          <span class="customer-email">{order.customerEmail}</span>
                        </div>
                      </td>
                      <td>{new Date(order.createdAt).toLocaleDateString('es-CO')}</td>
                      <td class="order-total">{formatCurrency(order.total)}</td>
                      <td>
                        <span class={`status-badge status-${order.status}`}>
                          {order.status === 'paid' ? 'Pagado' : 
                           order.status === 'shipped' ? 'Enviado' : 
                           order.status === 'cancelled' ? 'Cancelado' : 'Pendiente'}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    ) : (
      <div class="dashboard-card hud-panel">
        <div class="card-header">
          <h2>Contenido Reciente</h2>
          <a href="/admin/paginas" class="btn btn-secondary btn-sm">Ver Todo</a>
        </div>
        <div class="card-body">
          {recentContent.length === 0 ? (
            <div class="empty-state">
              <span class="empty-icon">📂</span>
              <p>No hay contenidos creados.</p>
              <p class="empty-sub">Comienza creando una página en la barra lateral.</p>
            </div>
          ) : (
            <div class="table-responsive">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Título</th>
                    <th>Tipo</th>
                    <th>Slug</th>
                    <th>Estado</th>
                  </tr>
                </thead>
                <tbody>
                  {recentContent.map((content) => (
                    <tr>
                      <td>
                        <span class="customer-name">{content.title}</span>
                      </td>
                      <td>
                        <span class={`type-badge type-${content.type}`} style="font-size: 0.7rem; padding: 2px 6px;">
                          {content.type === 'post' ? 'Blog' : 'Página'}
                        </span>
                      </td>
                      <td>
                        <code style="font-size: 0.8rem; color: var(--color-primary-light);">{content.slug}</code>
                      </td>
                      <td>
                        <span class={`status-dot-badge ${content.published === 1 ? 'pub' : 'draft'}`}>
                          <span class="dot" style="width:6px; height:6px;"></span>
                          <span style="font-size: 0.8rem;">{content.published === 1 ? 'Activo' : 'Borrador'}</span>
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    )}

    <!-- Columna Derecha: Accesos Rápidos y Ayuda -->
    <div class="dashboard-card hud-panel">
      <div class="card-header">
        <h2>Accesos Rápidos</h2>
      </div>
      <div class="card-body quick-actions-body">
        <div class="quick-actions-grid">
          <a href="/admin/paginas/crear" class="quick-action-item">
            <span class="action-icon">➕📄</span>
            <div class="action-details">
              <h4>Crear Página</h4>
              <p>Diseña una página estática o entrada de blog.</p>
            </div>
          </a>

          {isStoreEnabled && (
            <a href="/admin/productos/crear" class="quick-action-item">
              <span class="action-icon">➕🛍️</span>
              <div class="action-details">
                <h4>Agregar Producto</h4>
                <p>Sube un nuevo producto a tu tienda virtual.</p>
              </div>
            </a>
          )}

          <a href="/admin/paginas" class="quick-action-item">
            <span class="action-icon">✏️📄</span>
            <div class="action-details">
              <h4>Administrar Páginas</h4>
              <p>Modifica el SEO y texto del sitio público.</p>
            </div>
          </a>
        </div>

        <div class="system-status-box">
          <h4>Telemetría del CMS</h4>
          <div class="status-indicator">
            <span class="indicator-dot active"></span>
            <p>Soporte de Vida: Núcleo Astro Híbrido Activo</p>
          </div>
          <div class="status-indicator">
            <span class="indicator-dot active"></span>
            <p>SQLite: local.db conectada e integrada</p>
          </div>
          <div class="status-indicator">
            <span class="indicator-dot active" style={!isStoreEnabled ? "background-color: var(--text-muted-dark); box-shadow: none;" : ""}></span>
            <p>Tienda Virtual: {isStoreEnabled ? 'Habilitada 🛍️' : 'Desactivada 🔒'}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  /* Grid de Estadísticas */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }

  .stat-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px;
  }

  .stat-icon {
    font-size: 2rem;
    width: 60px;
    height: 60px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background: hsla(222, 25%, 15%, 0.5);
    border: 1px solid var(--border-light);
  }

  .icon-blue { color: var(--color-secondary-light); border-color: hsla(190, 95%, 45%, 0.3); }
  .icon-purple { color: var(--color-primary-light); border-color: hsla(263, 90%, 63%, 0.3); }
  .icon-cyan { color: hsl(180, 100%, 50%); border-color: hsla(180, 100%, 50%, 0.3); }
  .icon-green { color: var(--color-success); border-color: hsla(142, 70%, 45%, 0.3); }

  .stat-info h3 {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .stat-number {
    font-size: 1.8rem;
    font-weight: 800;
    font-family: var(--font-display);
    line-height: 1.1;
    color: var(--text-main);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted-dark);
  }

  /* Grid del Dashboard */
  .dashboard-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 30px;
  }

  .dashboard-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .card-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    font-family: var(--font-display);
  }

  .btn-sm {
    font-size: 0.8rem;
    padding: 6px 14px;
    border-radius: var(--radius-sm);
  }

  /* Estados vacíos */
  .empty-state {
    text-align: center;
    padding: 40px 20px;
  }

  .empty-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 12px;
  }

  .empty-sub {
    font-size: 0.8rem;
    color: var(--text-muted-dark);
    margin-top: 4px;
  }

  /* Tablas */
  .table-responsive {
    overflow-x: auto;
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .admin-table th {
    padding: 12px 16px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-light);
  }

  .admin-table td {
    padding: 14px 16px;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--border-light);
  }

  .admin-table tr:last-child td {
    border-bottom: none;
  }

  .customer-info {
    display: flex;
    flex-direction: column;
  }

  .customer-name {
    font-weight: 600;
    color: var(--text-main);
  }

  .customer-email {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .order-total {
    font-weight: 700;
    font-family: var(--font-display);
  }

  /* Estados (badges) */
  .status-badge {
    display: inline-block;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-pending { background-color: hsla(38, 92%, 50%, 0.15); color: var(--color-warning); }
  .status-paid { background-color: hsla(142, 70%, 45%, 0.15); color: var(--color-success); }
  .status-shipped { background-color: hsla(190, 95%, 45%, 0.15); color: var(--color-secondary-light); }
  .status-cancelled { background-color: hsla(350, 89%, 60%, 0.15); color: var(--color-danger); }

  /* Accesos Rápidos */
  .quick-actions-body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .quick-actions-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .quick-action-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: hsla(222, 25%, 5%, 0.4);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    transition: var(--transition-fast);
  }

  .quick-action-item:hover {
    background: var(--bg-surface-hover);
    border-color: var(--color-primary-light);
    transform: translateY(-2px);
  }

  .action-icon {
    font-size: 1.5rem;
  }

  .action-details h4 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-main);
  }

  .action-details p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  /* Estado del sistema */
  .system-status-box {
    border-top: 1px solid var(--border-light);
    padding-top: 20px;
  }

  .system-status-box h4 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .indicator-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background-color: var(--text-muted-dark);
  }

  .indicator-dot.active {
    background-color: var(--color-success);
    box-shadow: 0 0 8px var(--color-success);
  }
</style>

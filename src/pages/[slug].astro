---
import Layout from '../layouts/Layout.astro';
import { db, postsPages } from '../db/client';
import { eq, and } from 'drizzle-orm';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

// Buscar la página estática publicada
const result = await db
  .select()
  .from(postsPages)
  .where(
    and(
      eq(postsPages.slug, slug),
      eq(postsPages.type, 'page'),
      eq(postsPages.published, 1)
    )
  )
  .limit(1);

const page = result[0];

if (!page) {
  // Retornar respuesta 404 si la página no existe
  return new Response(null, {
    status: 404,
    statusText: 'Not Found'
  });
}
---

<Layout 
  title={page.title} 
  description={page.metaDescription || undefined}
  metaTitle={page.metaTitle || undefined}
>
  <article class="static-page-container">
    <header class="page-header">
      <h1>{page.title}</h1>
      <div class="header-divider"></div>
    </header>
    
    <section class="page-content" set:html={page.content} />
  </article>
</Layout>

<style>
  .static-page-container {
    max-width: 800px;
    margin: 40px auto;
    padding: 0 20px;
  }

  .page-header {
    margin-bottom: 40px;
    text-align: center;
  }

  .page-header h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 16px;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .header-divider {
    width: 60px;
    height: 4px;
    background: var(--gradient-primary);
    margin: 0 auto;
    border-radius: var(--radius-full);
  }

  /* Estilos para el renderizado del HTML inyectado de TipTap */
  .page-content {
    font-size: 1.15rem;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .page-content :global(> * + *) {
    margin-top: 1.2em;
  }

  .page-content :global(h1) {
    font-size: 2.2rem;
    margin-top: 1.8em;
    margin-bottom: 0.6em;
    color: var(--text-main);
    font-family: var(--font-display);
  }

  .page-content :global(h2) {
    font-size: 1.7rem;
    margin-top: 1.6em;
    margin-bottom: 0.5em;
    color: var(--text-main);
    font-family: var(--font-display);
  }

  .page-content :global(h3) {
    font-size: 1.3rem;
    margin-top: 1.4em;
    margin-bottom: 0.4em;
    color: var(--text-main);
  }

  .page-content :global(p) {
    margin-bottom: 1.2em;
  }

  .page-content :global(ul), .page-content :global(ol) {
    padding-left: 28px;
    margin-bottom: 1.2em;
  }

  .page-content :global(li) {
    margin-bottom: 0.4em;
  }

  .page-content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: 8px 20px;
    margin: 24px 0;
    font-style: italic;
    background: hsla(222, 25%, 8%, 0.4);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--text-main);
  }

  .page-content :global(pre) {
    background: hsla(222, 25%, 3%, 0.8);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    padding: 16px 20px;
    font-family: monospace;
    color: var(--color-secondary-light);
    overflow-x: auto;
    margin: 24px 0;
  }
</style>

---
import '../styles/global.css';

import { getSetting } from '../lib/settings';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const { 
  title, 
  description = "CMS Base ultra-rápido, moderno y modular optimizado para SEO y e-commerce.", 
  image = "/og-image.png",
  canonicalURL = Astro.url.href
} = Astro.props;

const isStoreEnabled = (await getSetting('enable_store', 'true')) === 'true';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <!-- Metadatos Básicos -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Principal -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />
  </head>
  <body>
    <!-- Navbar simple premium -->
    <header class="main-header glass-panel">
      <div class="nav-container">
        <a href="/" class="logo">
          <span>CMS</span>Base
        </a>
        <nav class="nav-links">
          <a href="/">Inicio</a>
          {isStoreEnabled && <a href="/productos">Tienda</a>}
          <a href="/blog">Blog</a>
          <a href="/admin" class="btn btn-secondary nav-admin-btn">Admin</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <slot />
    </main>

    <footer class="main-footer">
      <p>&copy; {new Date().getFullYear()} CMS Base. Hecho 100% a medida con tecnología moderna.</p>
    </footer>
  </body>
</html>

<style>
  /* Menú de Navegación Simple y Neutro */
  .main-header {
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-light);
    padding: 16px 20px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  
  .logo {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-main);
  }
  
  .logo span {
    color: var(--color-primary-light);
  }
  
  .nav-links {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  
  .nav-links a:not(.btn) {
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-muted);
  }
  
  .nav-links a:not(.btn):hover {
    color: var(--text-main);
  }
  
  .nav-admin-btn {
    padding: 6px 14px;
    font-size: 0.85rem;
  }
  
  /* Área de Contenido Principal */
  .main-content {
    flex: 1;
    max-width: 1200px;
    width: 100%;
    margin: 40px auto;
    padding: 0 20px;
  }
  
  /* Pie de Página Minimalista */
  .main-footer {
    text-align: center;
    padding: 30px 20px;
    border-top: 1px solid var(--border-light);
    margin-top: 60px;
    font-size: 0.85rem;
    color: var(--text-muted-dark);
  }
</style>

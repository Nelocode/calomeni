---
import '../styles/global.css';
import '../styles/admin.css';


import { getSetting } from '../lib/settings';

interface Props {
  title: string;
}

const { title } = Astro.props;

// El usuario es inyectado de forma segura por el middleware en Astro.locals.user
const user = Astro.locals.user || { username: 'Admin', id: '' };
const currentPath = Astro.url.pathname;

// Consultar configuración de la tienda
const isStoreEnabled = (await getSetting('enable_store', 'true')) === 'true';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Panel de Control</title>
  </head>
  <body class="admin-body">
    <div class="admin-container">
      <!-- Sidebar de Navegación Lateral -->
      <aside class="admin-sidebar">
        <div class="sidebar-brand">
          <a href="/">
            <span>CMS</span>Base
          </a>
        </div>
        
        <nav class="sidebar-nav">
          <a href="/admin" class={`nav-item ${currentPath === '/admin' ? 'active' : ''}`}>
            <span class="icon">📊</span> Escritorio
          </a>
          <a href="/admin/paginas" class={`nav-item ${currentPath.startsWith('/admin/paginas') ? 'active' : ''}`}>
            <span class="icon">📄</span> Páginas y Blog
          </a>
          {isStoreEnabled && (
            <>
              <a href="/admin/productos" class={`nav-item ${currentPath.startsWith('/admin/productos') ? 'active' : ''}`}>
                <span class="icon">🛍️</span> Productos
              </a>
              <a href="/admin/ordenes" class={`nav-item ${currentPath.startsWith('/admin/ordenes') ? 'active' : ''}`}>
                <span class="icon">💳</span> Pedidos
              </a>
            </>
          )}
          <a href="/admin/configuracion" class={`nav-item ${currentPath.startsWith('/admin/configuracion') ? 'active' : ''}`}>
            <span class="icon">⚙️</span> Configuración
          </a>
        </nav>

        <div class="sidebar-footer">
          <div class="user-info">
            <div class="avatar">{user.username[0].toUpperCase()}</div>
            <div class="details">
              <p class="name">{user.username}</p>
              <p class="role">Administrador</p>
            </div>
          </div>
          <form action="/admin/logout" method="POST" class="logout-form">
            <button type="submit" class="btn btn-secondary logout-btn">
              <span>🚪</span> Cerrar Sesión
            </button>
          </form>
        </div>
      </aside>

      <!-- Contenido Principal -->
      <div class="admin-main">
        <header class="admin-header hud-panel">
          <h1>{title}</h1>
          <div class="header-actions">
            <a href="/" target="_blank" class="btn btn-secondary view-site-btn">
              <span>🌐</span> Ver Sitio Público
            </a>
          </div>
        </header>

        <main class="admin-content animate-fade-in">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  .admin-body {
    background-color: hsl(222, 25%, 3%);
    min-height: 100vh;
    overflow: hidden;
  }

  .admin-container {
    display: grid;
    grid-template-columns: 260px 1fr;
    height: 100vh;
  }

  /* Sidebar */
  .admin-sidebar {
    background-color: var(--bg-sidebar);
    border-right: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
    padding: 24px;
    height: 100%;
  }

  .sidebar-brand {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 800;
    margin-bottom: 40px;
  }

  .sidebar-brand a {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .sidebar-brand span {
    color: var(--text-main);
    -webkit-text-fill-color: initial;
    margin-right: 2px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: var(--transition-fast);
    border: 1px solid transparent;
  }

  .nav-item:hover {
    background-color: hsla(180, 100%, 45%, 0.05);
    color: var(--color-primary);
    border-color: hsla(180, 100%, 45%, 0.15);
    transform: translateX(4px);
  }

  .nav-item.active {
    background: hsla(180, 100%, 45%, 0.15);
    border-color: var(--color-primary);
    color: var(--color-primary);
    font-weight: 700;
    box-shadow: var(--glow-primary);
    text-shadow: var(--glow-text);
  }
  
  .nav-item.active .icon {
    filter: drop-shadow(0 0 5px var(--color-primary));
  }

  .sidebar-footer {
    border-top: 1px solid var(--border-light);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .avatar {
    width: 36px;
    height: 36px;
    background: hsla(180, 100%, 45%, 0.1);
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    box-shadow: var(--glow-primary);
  }

  .details .name {
    color: var(--text-main);
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .details .role {
    color: var(--color-primary-light);
    font-size: 0.75rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
  }

  .logout-form {
    width: 100%;
  }

  .logout-btn {
    width: 100%;
    justify-content: flex-start;
    padding: 8px 16px;
    font-size: 0.8rem;
    border-radius: var(--radius-sm);
  }

  /* Area de Contenido Principal */
  .admin-main {
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow-y: auto;
  }

  .admin-header {
    background: hsla(222, 25%, 5%, 0.6);
    margin: 20px 24px 0 24px;
    padding: 16px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: var(--radius-md);
  }

  .admin-header h1 {
    font-size: 1.6rem;
    font-weight: 700;
  }

  .view-site-btn {
    font-size: 0.85rem;
    padding: 8px 16px;
    border-radius: var(--radius-full);
  }

  .admin-content {
    flex: 1;
    padding: 24px;
  }
</style>
